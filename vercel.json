{
  "version": 2,
  "buildCommand": "cd apps/web && npm install && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "cd apps/web && npm install",
  "devCommand": "cd apps/web && npm run dev",
  "rewrites": [
    {
      "source": "/api-proxy/(.*)",
      "destination": "https://neuropetrix.onrender.com/$1"
    },
    {
      "source": "/legacy/(.*)",
      "destination": "https://neuropetrix.onrender.com/legacy/$1"
    }
  ],
  "env": {
    "API_BASE": "https://neuropetrix.onrender.com",
    "NEXT_PUBLIC_API_BASE": "/api-proxy"
  }
}
